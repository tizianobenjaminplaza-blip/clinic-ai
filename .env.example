# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://clinic:clinic@localhost:5432/clinic_ai?schema=public

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx          # Precio del plan del agente
STRIPE_SUCCESS_URL=http://localhost:3000/onboarding/success
STRIPE_CANCEL_URL=http://localhost:3000/pricing

# ─── Claude API (Anthropic) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-opus-4-8

# ─── WhatsApp (Meta Cloud API) ────────────────────────────
WHATSAPP_VERIFY_TOKEN=my-verify-token
WHATSAPP_ACCESS_TOKEN=EAAxxx
WHATSAPP_PHONE_NUMBER_ID=xxx
WHATSAPP_API_VERSION=v21.0

# ─── Email (onboarding / reportes) ────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=xxx
SMTP_PASS=xxx
EMAIL_FROM="Clinic AI <noreply@clinic-ai.com>"
