{
  "expo": {
    "name": "Clinic AI",
    "slug": "clinic-ai-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1d4ed8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.clinicai.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1d4ed8"
      },
      "package": "com.clinicai.mobile"
    },
    "plugins": [
      "expo-router",
      ["expo-notifications", { "icon": "./assets/icon.png" }],
      "expo-secure-store"
    ],
    "scheme": "clinicai"
  }
}
