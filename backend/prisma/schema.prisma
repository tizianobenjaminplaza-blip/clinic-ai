// Clinic AI Agent — Prisma schema
// PostgreSQL. Run: npm run prisma:migrate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// Core tenant
// ─────────────────────────────────────────────────────────
model Clinic {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String?
  whatsappPhone String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscription Subscription?
  services     Service[]
  teamMembers  TeamMember[]
  faqs         FAQ[]
  patients     Patient[]
  payments     Payment[]
  leads        Lead[]
  abTests      ABTestingConfig[]
  reports      LeadReport[]
}

model Service {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  clinicId    String
  clinic      Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  @@index([clinicId])
}

model TeamMember {
  id       String @id @default(cuid())
  name     String
  role     String
  email    String
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model FAQ {
  id       String @id @default(cuid())
  question String
  answer   String
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

// ─────────────────────────────────────────────────────────
// Patients & appointments
// ─────────────────────────────────────────────────────────
model Patient {
  id        String   @id @default(cuid())
  phone     String
  name      String?
  email     String?
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  appointments Appointment[]

  @@unique([clinicId, phone])
  @@index([clinicId])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Appointment {
  id        String            @id @default(cuid())
  patientId String
  serviceId String
  dateTime  DateTime
  status    AppointmentStatus @default(PENDING)
  patient   Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  service   Service           @relation(fields: [serviceId], references: [id])

  @@index([patientId])
  @@index([serviceId])
}

// ─────────────────────────────────────────────────────────
// Billing
// ─────────────────────────────────────────────────────────
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Payment {
  id              String        @id @default(cuid())
  clinicId        String
  stripeSessionId String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("usd")
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  clinic          Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

enum SubscriptionPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELLED
}

model Subscription {
  id            String             @id @default(cuid())
  clinicId      String             @unique
  plan          SubscriptionPlan   @default(STARTER)
  status        SubscriptionStatus @default(INACTIVE)
  isAgentActive Boolean            @default(false)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  clinic        Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────
// Lead tracking
// ─────────────────────────────────────────────────────────
enum LeadStatus {
  NEW
  ENGAGED
  QUALIFIED
  CONVERTED
  LOST
}

enum SenderRole {
  LEAD
  AGENT
}

model Lead {
  id              String     @id @default(cuid())
  clinicId        String
  phone           String
  name            String?
  email           String?
  tags            String[]   @default([])
  status          LeadStatus @default(NEW)
  messageCount    Int        @default(0)
  lastMessageDate DateTime?
  inactivityDays  Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  clinic          Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  interactions   LeadInteraction[]
  score          LeadScore?
  followUps      FollowUpMessage[]
  abTestResults  LeadABTestResult[]

  @@unique([clinicId, phone])
  @@index([clinicId])
  @@index([status])
}

model LeadInteraction {
  id         String     @id @default(cuid())
  leadId     String
  senderRole SenderRole
  content    String
  timestamp  DateTime   @default(now())
  lead       Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model LeadScore {
  id                    String   @id @default(cuid())
  leadId                String   @unique
  engagementScore       Float    @default(0)
  conversionProbability Float    @default(0)
  recommendedAction     String?
  updatedAt             DateTime @updatedAt
  lead                  Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model FollowUpMessage {
  id          String    @id @default(cuid())
  leadId      String
  messageType String
  content     String
  sentAt      DateTime?
  response    String?
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

// ─────────────────────────────────────────────────────────
// A/B testing
// ─────────────────────────────────────────────────────────
enum ABTestStatus {
  DRAFT
  RUNNING
  COMPLETED
}

model ABTestingConfig {
  id           String       @id @default(cuid())
  clinicId     String
  status       ABTestStatus @default(DRAFT)
  generatedAt  DateTime     @default(now())
  consentGiven Boolean      @default(false)
  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  variants MessageVariant[]

  @@index([clinicId])
}

model MessageVariant {
  id            String  @id @default(cuid())
  abTestId      String
  name          String
  message       String
  tone          String
  includesOffer Boolean @default(false)
  abTest        ABTestingConfig @relation(fields: [abTestId], references: [id], onDelete: Cascade)

  results LeadABTestResult[]

  @@index([abTestId])
}

model LeadABTestResult {
  id        String         @id @default(cuid())
  variantId String
  leadId    String
  sent      Boolean        @default(false)
  converted Boolean        @default(false)
  variant   MessageVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([leadId])
}

// ─────────────────────────────────────────────────────────
// Reports
// ─────────────────────────────────────────────────────────
model LeadReport {
  id        String   @id @default(cuid())
  clinicId  String
  period    String
  pdfUrl    String?
  createdAt DateTime @default(now())
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}
