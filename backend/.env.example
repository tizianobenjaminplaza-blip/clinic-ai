# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://clinicai:clinicai@localhost:5432/clinicai

# ── Stripe ──────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# https://dashboard.stripe.com/webhooks (endpoint: /api/payments/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID de tu plan mensual en Stripe
STRIPE_PRICE_ID=price_...
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard?payment=success
STRIPE_CANCEL_URL=http://localhost:3000/dashboard?payment=cancel

# ── Anthropic ───────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# ── WhatsApp Cloud API ──────────────────────────────────────
# https://developers.facebook.com → tu app → WhatsApp → API Setup
WHATSAPP_VERIFY_TOKEN=mi_token_secreto_cualquiera
WHATSAPP_ACCESS_TOKEN=EAA...
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_API_VERSION=v21.0

# ── Email (SMTP) ─────────────────────────────────────────────
# SendGrid: host=smtp.sendgrid.net port=587 user=apikey pass=SG....
# Resend:   host=smtp.resend.com  port=587 user=resend pass=re_....
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG...
EMAIL_FROM=Clinic AI <noreply@tudominio.com>
